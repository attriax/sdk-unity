/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/
/.utmp/

# Native build tool caches that can appear anywhere under the tree (e.g. inside
# the Android .androidlib plugin folder) — never track these regardless of depth.
**/.gradle/
**/.idea/

# Stray .meta files Unity generates for the transient project folders above when
# this package is opened as a standalone Unity project. If committed, consumers
# that embed this package (e.g. tester-unity) try to import those folders and hit
# import loops / SourceAssetDB time-mismatch errors. Never track these.
/[Ll]ibrary.meta
/[Tt]emp.meta
/[Oo]bj.meta
/[Bb]uild.meta
/[Bb]uilds.meta
/[Ll]ogs.meta
/[Uu]ser[Ss]ettings.meta
/[Mm]emoryCaptures.meta
/dist.meta

*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb

/.vs/
/dist/*.log
/dist/unity-editmode-test-results.xml
/.generated-sdk-client-tmp/

# Build outputs from the dev/test project's platform build scripts
# (Assets/Editor/Attriax{Android,Ios,WebGL,Desktop}Build.cs), plus stray
# platform artifacts that can land elsewhere.
*.apk
*.aab

# Unity test results (EditMode/PlayMode artifacts, regenerated on every run)
/[Tt]est[Rr]esults/
/[Tt]est[Rr]esults.meta
/[Tt]est[Rr]esults-*.xml
/[Tt]est[Rr]esults-*.xml.meta
